-#define __shfl_sync(mask, var, laneMask, ...) __shfl(var, laneMask, ##__VA_ARGS__)
-#define __shfl_up_sync(mask, var, laneMask, ...) __shfl_up(var, laneMask, ##__VA_ARGS__)
-#define __shfl_xor_sync(mask, var, laneMask, ...) __shfl_xor(var, laneMask, ##__VA_ARGS__)
+// CUDA __shfl_*_sync → HIP equivalents.
+// The mask argument is dropped (HIP has no per-lane predicate masking).
+// Each family supports both 3-arg (no width) and 4-arg (explicit width) call forms.
+// 'warpSize' is a runtime device variable not available at macro-expansion time;
+// llama.cpp hard-codes WARP_SIZE=32 in common.cuh and targets wave32 mode, so 32
+// is the correct compile-time default here.
+//
+// Dispatch trick: the selector macro counts arguments and picks the right helper.
+//   __GGML_SHFL_SEL(a,b,c,d, NAME, ...) selects NAME from position 5.
+//   4-arg call  → fills _1 _2 _3 _4 → NAME = *4 helper ✓
+//   3-arg call  → fills _1 _2 _3    → NAME = *3 helper ✓
+#define __GGML_SHFL_SEL(_1, _2, _3, _4, NAME, ...) NAME
+
+#define __GGML_SHFL_SYNC3(mask, var, srcLane)        __shfl(var, srcLane, 32)
+#define __GGML_SHFL_SYNC4(mask, var, srcLane, width) __shfl(var, srcLane, width)
+#define __shfl_sync(...)      __GGML_SHFL_SEL(__VA_ARGS__, __GGML_SHFL_SYNC4,  __GGML_SHFL_SYNC3) (__VA_ARGS__)
+
+#define __GGML_SHFL_UP3(mask, var, delta)        __shfl_up(var, delta, 32)
+#define __GGML_SHFL_UP4(mask, var, delta, width) __shfl_up(var, delta, width)
+#define __shfl_up_sync(...)   __GGML_SHFL_SEL(__VA_ARGS__, __GGML_SHFL_UP4,   __GGML_SHFL_UP3)   (__VA_ARGS__)
+
+#define __GGML_SHFL_XOR3(mask, var, laneMask)        __shfl_xor(var, laneMask, 32)
+#define __GGML_SHFL_XOR4(mask, var, laneMask, width) __shfl_xor(var, laneMask, width)
+#define __shfl_xor_sync(...)  __GGML_SHFL_SEL(__VA_ARGS__, __GGML_SHFL_XOR4,  __GGML_SHFL_XOR3)  (__VA_ARGS__)
+
+#define __GGML_SHFL_DOWN3(mask, var, delta)        __shfl_down(var, delta, 32)
+#define __GGML_SHFL_DOWN4(mask, var, delta, width) __shfl_down(var, delta, width)
+#define __shfl_down_sync(...) __GGML_SHFL_SEL(__VA_ARGS__, __GGML_SHFL_DOWN4, __GGML_SHFL_DOWN3) (__VA_ARGS__)
+
 #define __all_sync(mask, var) __all(var)
 #define __any_sync(mask, var) __any(var)
+#define __ballot_sync(mask, var) ((uint32_t)__ballot(var))
 #define cublasStrsmBatched hipblasStrsmBatched
 #define cublasCreate hipblasCreate
 #define cublasDestroy hipblasDestroy


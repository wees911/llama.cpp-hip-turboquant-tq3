+// TQ3_1S KQ dot product for FA: two half-block scales, WHT-rotated Lloyd-Max codebook.
+template <int D, int nthreads>
+static __device__ __forceinline__ float vec_dot_fattn_vec_KQ_tq3_1s(
+    const char * __restrict__ K_c, const void * __restrict__ Q_v,
+    const int * __restrict__ Q_q8, const void * __restrict__ Q_ds_v) {
+
+    static constexpr int8_t levels[8] = {-127, -79, -45, -14, 14, 45, 79, 127};
+    const block_tq3_1s * K_tq3 = (const block_tq3_1s *) K_c;
+    GGML_UNUSED(Q_q8); GGML_UNUSED(Q_ds_v);
+
+    float sum = 0.0f;
+#pragma unroll
+    for (int k0 = 0; k0 < D/2; k0 += nthreads) {
+        const int k  = k0 + (threadIdx.x % nthreads);
+        // Each k covers 2 elements; map to subgroup (8 elements) and position within it
+        const int ib = (k * 2) / QK_TQ3_0;          // block index
+        const int g  = ((k * 2) % QK_TQ3_0) / 8;    // subgroup 0-3
+        const int r  = ((k * 2) % QK_TQ3_0) % 8;    // position within subgroup (even)
+
+        const uint8_t * qp = K_tq3[ib].qs + g * 3;
+        const uint32_t packed = (uint32_t)qp[0] | ((uint32_t)qp[1] << 8) | ((uint32_t)qp[2] << 16);
+
+        const float d = (g < 2) ? __half2float(K_tq3[ib].d0) : __half2float(K_tq3[ib].d1);
+        const float v0 = levels[(packed >> (3 * r))       & 7] * (d * (2.1519f / 127.0f));
+        const float v1 = levels[(packed >> (3 * (r + 1))) & 7] * (d * (2.1519f / 127.0f));
+
+#ifdef V_DOT2_F32_F16_AVAILABLE
+        const float2 qf = __half22float2(((const half2 *) Q_v)[k0/nthreads]);
+        sum += v0 * qf.x + v1 * qf.y;
+#else
+        const float2 qv = ((const float2 *) Q_v)[k0/nthreads];
+        sum += v0 * qv.x + v1 * qv.y;
+#endif
+    }
+    return sum;
+}
+
+// TQ3_4S KQ dot product for FA: four E3M5 per-8 scales, WHT-rotated Lloyd-Max codebook.
+template <int D, int nthreads>
+static __device__ __forceinline__ float vec_dot_fattn_vec_KQ_tq3_4s(
+    const char * __restrict__ K_c, const void * __restrict__ Q_v,
+    const int * __restrict__ Q_q8, const void * __restrict__ Q_ds_v) {
+
+    static constexpr int8_t levels[8] = {-127, -79, -45, -14, 14, 45, 79, 127};
+    const block_tq3_4s * K_tq3 = (const block_tq3_4s *) K_c;
+    GGML_UNUSED(Q_q8); GGML_UNUSED(Q_ds_v);
+
+    float sum = 0.0f;
+#pragma unroll
+    for (int k0 = 0; k0 < D/2; k0 += nthreads) {
+        const int k  = k0 + (threadIdx.x % nthreads);
+        const int ib = (k * 2) / QK_TQ3_0;
+        const int g  = ((k * 2) % QK_TQ3_0) / 8;
+        const int r  = ((k * 2) % QK_TQ3_0) % 8;
+
+        const uint8_t * qp = K_tq3[ib].qs + g * 3;
+        const uint32_t packed = (uint32_t)qp[0] | ((uint32_t)qp[1] << 8) | ((uint32_t)qp[2] << 16);
+
+        // E3M5 decode: 2^(exp-9) * (1 + mant/32)
+        const uint8_t dbyte = K_tq3[ib].d[g];
+        float d = 0.0f;
+        if (dbyte != 0) {
+            const uint32_t bits = (((uint32_t)(dbyte >> 5) + 118u) << 23) | ((uint32_t)(dbyte & 31u) << 18);
+            d = __uint_as_float(bits);
+        }
+
+        const float v0 = levels[(packed >> (3 * r))       & 7] * (d * (2.1519f / 127.0f));
+        const float v1 = levels[(packed >> (3 * (r + 1))) & 7] * (d * (2.1519f / 127.0f));
+
+#ifdef V_DOT2_F32_F16_AVAILABLE
+        const float2 qf = __half22float2(((const half2 *) Q_v)[k0/nthreads]);
+        sum += v0 * qf.x + v1 * qf.y;
+#else
+        const float2 qv = ((const float2 *) Q_v)[k0/nthreads];
+        sum += v0 * qv.x + v1 * qv.y;
+#endif
+    }
+    return sum;
+}
